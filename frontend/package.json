{
  "name": "@musical-ocr/frontend",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --web",
    "build": "npm run typecheck && expo export --platform web",
    "preview": "npx serve dist",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@expo/metro-runtime": "^57.0.6",
    "expo": "^57.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.83.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.2",
    "typescript": "^7.0.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts?(x)"
    ]
  }
}
